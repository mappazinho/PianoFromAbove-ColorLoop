IDM_MAINMENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Practice Song...\tCtrl+O",   ID_FILE_PRACTICESONG
        MENUITEM "P&ractice Using Custom Settings...", ID_FILE_PRACTICESONGCUSTOM
        MENUITEM "Pl&ay Song...",               ID_FILE_PLAYSONG
        MENUITEM "&Learn Song...",              ID_FILE_LEARNSONG
        MENUITEM "&Close File\tCtrl+W",         ID_FILE_CLOSEFILE
        MENUITEM SEPARATOR
        POPUP "Librar&y"
        BEGIN
            MENUITEM "Add &File(s)...\tCtrl+F",     ID_FILE_ADDFILE
            MENUITEM "Add Fol&der...\tCtrl+D",      ID_FILE_ADDFOLDER
        END
    END
    POPUP "&Play"
    BEGIN
        MENUITEM "&Play/Pause\tSpace",          ID_PLAY_PLAYPAUSE
        MENUITEM "&Stop\tPeriod",               ID_PLAY_STOP
        MENUITEM "Skip &Fwd\tRight",            ID_PLAY_SKIPFWD
        MENUITEM "Skip &Back\tLeft",            ID_PLAY_SKIPBACK
        MENUITEM SEPARATOR
        MENUITEM "&Loop\tCtrl+L",               ID_PLAY_LOOP
        POPUP "L&earn"
        BEGIN
            MENUITEM "&Adaptive",                   ID_LEARN_ADAPTIVE
            MENUITEM "&Waiting",                    ID_LEARN_WAITING, CHECKED
            MENUITEM SEPARATOR
            MENUITEM "Ne&xt Track\tCtrl+X",         ID_LEARN_NEXTTRACK
        END
        MENUITEM SEPARATOR
        MENUITEM "F&aster Playback\tDown",      ID_PLAY_INCREASERATE
        MENUITEM "Sl&ower Playback\tUp",        ID_PLAY_DECREASERATE
        MENUITEM "&Reset\tR",                   ID_PLAY_RESET
        MENUITEM SEPARATOR
        MENUITEM "Faster &Notes\tShift+Up",     ID_PLAY_FASTERNOTES
        MENUITEM "Slower No&tes\tShift+Down",   ID_PLAY_SLOWERNOTE
        MENUITEM SEPARATOR
        MENUITEM "&Volume Up\tAlt+Up",          ID_PLAY_VOLUMEUP
        MENUITEM "V&olume Down\tAlt+Down",      ID_PLAY_VOLUMEDOWN
        MENUITEM "&Mute\tM",                    ID_PLAY_MUTE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Playback Toolbar\tCtrl+T",   ID_VIEW_CONTROLS, CHECKED
        MENUITEM "&Library Panel\tCtrl+Y",      ID_VIEW_LIBRARY, CHECKED
        MENUITEM "&Keyboard\tCtrl+K",           ID_VIEW_KEYBOARD, CHECKED
        MENUITEM "&Note Labels\tCtrl+N",        ID_VIEW_NOTELABELS
        MENUITEM SEPARATOR
        MENUITEM "&Always On Top\tCtrl+A",      ID_VIEW_ALWAYSONTOP
        MENUITEM SEPARATOR
        MENUITEM "&Full Screen\tAlt+Enter",     ID_VIEW_FULLSCREEN
        MENUITEM "Mo&ve and Zoom\tCtrl+V",      ID_VIEW_MOVEANDZOOM
        MENUITEM "Reset Move and &Zoom\tCtrl+Z", ID_VIEW_RESETMOVEANDZOOM
    END
    POPUP "&Options"
    BEGIN
        MENUITEM "&Preferences...\tCtrl+P",     ID_OPTIONS_PREFERENCES
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Online FAQ...",              ID_HELP_ONLINEFAQ
        MENUITEM "&About PFA...",               ID_HELP_ABOUT
    END
END

IDR_CONTEXTMENU MENU
BEGIN
    POPUP "Library"
    BEGIN
        MENUITEM "&Practice Song",              ID_PRACTICE_DEFAULT
        MENUITEM "Practice Using &Custom Settings...", ID_PRACTICE_CUSTOM
        MENUITEM "Pl&ay Song",                  ID_PLAY_DEFAULT
        MENUITEM "&Learn Song",                 ID_LEARN_DEFAULT
        MENUITEM SEPARATOR
        MENUITEM "Add &File(s)...\tCtrl+F",     ID_FILE_ADDFILE
        MENUITEM "Add Fol&der...\tCtrl+D",      ID_FILE_ADDFOLDER
        MENUITEM "&Refresh",                    ID_FILE_REFRESH
    END
    POPUP "Graphics"
    BEGIN
        POPUP "&File"
        BEGIN
            MENUITEM "&Practice Song...\tCtrl+O",   ID_FILE_PRACTICESONG
            MENUITEM "Pl&ay Song...",               ID_FILE_PLAYSONG
            MENUITEM "&Learn Song...",              ID_FILE_LEARNSONG
